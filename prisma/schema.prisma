// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  balance       Float     @default(0)
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  userCards          UserCard[]
  transactions       Transaction[]
  openings           CaseOpening[]
  withdrawals        WithdrawRequest[]
  exchangesOffering  Exchange[]        @relation("ExchangeOffering")
  exchangesAccepting Exchange[]        @relation("ExchangeAccepting")
  battlesCreated     Battle[]          @relation("BattleCreator")
  battlesJoined      Battle[]          @relation("BattleJoiner")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CardCase {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?
  price       Float
  tier        CaseTier @default(STANDARD)
  game        CardGame @default(POKEMON)
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  cardCount   Int      @default(5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  caseCards   CaseCard[]
  openings    CaseOpening[]
  battles     Battle[]
}

model Card {
  id          String      @id @default(cuid())
  name        String
  imageUrl    String?
  rarity      CardRarity  @default(COMMON)
  value       Float
  game        CardGame    @default(POKEMON)
  pokemonType PokemonType @default(NORMAL)
  setName     String?
  cardNumber  String?
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  caseCards      CaseCard[]
  userCards      UserCard[]
  openingCards   OpeningCard[]
  exchangesWanted Exchange[]   @relation("ExchangeWanted")
}

model CaseCard {
  id       String @id @default(cuid())
  caseId   String
  cardId   String
  dropRate Float  // 0-100 percentage

  case     CardCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  card     Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([caseId, cardId])
}

model UserCard {
  id         String   @id @default(cuid())
  userId     String
  cardId     String
  obtainedAt DateTime @default(now())
  soldAt     DateTime?
  sold       Boolean  @default(false)
  withdrawn  Boolean  @default(false)

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  card            Card           @relation(fields: [cardId], references: [id])
  withdrawCards   WithdrawCard[]
  exchangeOffered Exchange?      @relation("ExchangeOffered")
  exchangeAccepted Exchange?     @relation("ExchangeAccepted")
}

model CaseOpening {
  id        String        @id @default(cuid())
  userId    String
  caseId    String
  totalCost Float
  createdAt DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  case         CardCase      @relation(fields: [caseId], references: [id])
  openingCards OpeningCard[]
}

model OpeningCard {
  id         String @id @default(cuid())
  openingId  String
  cardId     String

  opening    CaseOpening @relation(fields: [openingId], references: [id], onDelete: Cascade)
  card       Card        @relation(fields: [cardId], references: [id])
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  amount      Float
  type        TransactionType
  description String?
  stripeId    String?
  createdAt   DateTime        @default(now())

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

enum CardRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum PokemonType {
  NORMAL
  FIRE
  WATER
  GRASS
  ELECTRIC
  ICE
  FIGHTING
  POISON
  GROUND
  FLYING
  PSYCHIC
  BUG
  ROCK
  GHOST
  DRAGON
  DARK
  STEEL
  FAIRY
}

enum CaseTier {
  STARTER
  STANDARD
  PREMIUM
  ELITE
  LEGENDARY
}

enum CardGame {
  POKEMON
  ONE_PIECE
  MAGIC
  DRAGON_BALL
}

enum TransactionType {
  DEPOSIT
  PURCHASE
  SALE
  REFUND
  EXCHANGE
}

model Exchange {
  id               String         @id @default(cuid())
  createdAt        DateTime       @default(now())
  status           ExchangeStatus @default(OPEN)

  offeringUserId   String
  offeringUser     User           @relation("ExchangeOffering", fields: [offeringUserId], references: [id], onDelete: Cascade)
  offeredCardId    String         @unique
  offeredCard      UserCard       @relation("ExchangeOffered", fields: [offeredCardId], references: [id])

  wantedCardId     String
  wantedCard       Card           @relation("ExchangeWanted", fields: [wantedCardId], references: [id])

  acceptingUserId  String?
  acceptingUser    User?          @relation("ExchangeAccepting", fields: [acceptingUserId], references: [id])
  acceptedCardId   String?        @unique
  acceptedCard     UserCard?      @relation("ExchangeAccepted", fields: [acceptedCardId], references: [id])

  completedAt      DateTime?
}

enum ExchangeStatus {
  OPEN
  COMPLETED
  CANCELLED
}

model WithdrawRequest {
  id             String         @id @default(cuid())
  userId         String
  status         WithdrawStatus @default(PENDING)
  fullName       String
  email          String
  address        String
  city           String
  state          String
  zipCode        String
  country        String
  phone          String?
  notes          String?
  trackingNumber String?
  adminNotes     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards          WithdrawCard[]
}

model WithdrawCard {
  id         String          @id @default(cuid())
  withdrawId String
  userCardId String

  withdraw   WithdrawRequest @relation(fields: [withdrawId], references: [id], onDelete: Cascade)
  userCard   UserCard        @relation(fields: [userCardId], references: [id])
}

enum WithdrawStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String   // twitter, instagram, tiktok, youtube, discord, reddit, facebook, twitch
  url       String
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Battle {
  id           String       @id @default(cuid())
  status       BattleStatus @default(WAITING)
  caseId       String
  case         CardCase     @relation(fields: [caseId], references: [id])
  wager        Float        @default(0)

  creatorId          String
  creator            User         @relation("BattleCreator", fields: [creatorId], references: [id])
  creatorValue       Float?
  creatorCards       Json?
  creatorUserCardIds Json?

  joinerId           String?
  joiner             User?        @relation("BattleJoiner", fields: [joinerId], references: [id])
  joinerValue        Float?
  joinerCards        Json?
  joinerUserCardIds  Json?

  winnerId     String?

  expiresAt    DateTime
  createdAt    DateTime     @default(now())
}

enum BattleStatus {
  WAITING
  READY
  COMPLETE
  CANCELLED
  EXPIRED
}
